{
  "manifestVersion": 5,
  "id": "com.lapisraro.esquadro",
  "name": "ESQUADЯO",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "23.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "esquadroPanel",
      "label": {
        "default": "ESQUADЯO — Lápis Raro"
      },
      "minimumSize": {
        "width": 260,
        "height": 450
      },
      "preferredDockSize": {
        "width": 260,
        "height": 520
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "network": {
      "domains": "all"
    }
  }
}
